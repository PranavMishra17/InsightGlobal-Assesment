# Copy this file to .env and fill in your keys before running the app.

# Required — Claude synthesis, sufficiency eval, and web_search tool
CALUDE_API_KEY=your_claude_api_key_here

# Optional — raises PubMed rate limit from 3 req/sec to 10 req/sec
PUBMED_API_KEY=your_pubmed_api_key_here

# Optional — raises OpenFDA rate limit from 1 000/day to 120 000/day
OPENFDA_API_KEY=your_openfda_api_key_here
